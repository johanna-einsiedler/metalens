# Copy to .env (gitignored) and fill in for local dev. Loaded by scripts/dev.sh.
# Nothing here is required to run — the app works with own-API-key mode and
# sensible localhost defaults. Set the credit vars to test server-paid runs.

# --- Server-paid credit runs (optional) ---------------------------------------
# The model a keyless "Use my Metalens credits" run uses, plus the provider key
# it is charged against. Without BOTH, the credit toggle stays hidden.
PAPERLENS_CREDIT_MODEL=gemini-3.1-pro-preview
PAPERLENS_GOOGLE_KEY=
# PAPERLENS_OPENAI_KEY=
# PAPERLENS_ANTHROPIC_KEY=

# --- Overrides (defaults shown — usually leave commented) ---------------------
# PAPERLENS_DATABASE_URL=dbname=paperlens
# PAPERLENS_REDIS_URL=redis://localhost:6379
# PAPERLENS_STORAGE=local
# PAPERLENS_HOST=127.0.0.1
# PAPERLENS_PORT=8000
